{
  "model": {
    "provider": "openaiCompat",
    "modelName": "llama3.1",
    "baseUrl": "http://127.0.0.1:11434",
    "apiKey": "",
    "supportsTools": true,
    "supportsStreaming": true,
    "timeoutMs": 60000
  },
  "mcp": {
    "playwright": {
      "enabled": true,
      "transport": "stdio",
      "stdio": {
        "command": "bunx",
        "args": ["@playwright/mcp"],
        "env": {},
        "cwd": "."
      }
    },
    "postman": {
      "enabled": true,
      "transport": "stdio",
      "stdio": {
        "command": "bunx",
        "args": ["mcp-postman"],
        "env": {},
        "cwd": "."
      }
    }
  },
  "agent": {
    "maxIterations": 8,
    "toolTimeoutMs": 45000,
    "requestTimeoutMs": 60000
  }
}
